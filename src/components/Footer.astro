---
import { Image } from "astro:assets";
import logoImg from "@images/quote-logo-circle.webp";
---

<footer class="footer footer-horizontal bg-neutral text-neutral-content p-10">
  <aside class="mx-auto gap-4">
    <a href="/" aria-label="Return to Aspire Academy debating's home page"
      ><Image
        src={logoImg}
        alt="Logo for Aspire Academy debating"
        class="w-12"
      /></a
    >
    <div>
      <h2 class="text-lg font-semibold tracking-wide">Aspire Academy</h2>
      <p class="opacity-80">
        Sydney-based online debating and public speaking classes
      </p>
    </div>
  </aside>
  <section class="m-auto grid grid-cols-2 gap-8">
    <a
      class="btn btn-secondary btn-soft"
      href="/#free-consultation"
      role="button"
    >
      Free consultation<svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-right h-4 w-4"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M5 12l14 0"></path><path d="M13 18l6 -6"></path><path d="M13 6l6 6"
        ></path></svg
      >
    </a>
    <a class="btn btn-secondary" href="/enrol" role="button">
      Enrol now<svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-right h-4 w-4"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M5 12l14 0"></path><path d="M13 18l6 -6"></path><path d="M13 6l6 6"
        ></path></svg
      >
    </a>
  </section>
</footer>

<footer
  class="footer footer-horizontal text-neutral-content bg-neutral p-4 opacity-95"
>
  <aside class="mx-auto flex flex-row items-center opacity-70">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="icon icon-tabler icons-tabler-outline icon-tabler-copyright"
      ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
        d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"></path><path
        d="M14 9.75a3.016 3.016 0 0 0 -4.163 .173a2.993 2.993 0 0 0 0 4.154a3.016 3.016 0 0 0 4.163 .173"
      ></path></svg
    >
    <p class="text-xs">
      Copyright {new Date().getFullYear()} Aspire Academy
    </p>
  </aside>
</footer>
